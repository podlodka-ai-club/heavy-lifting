# Образец локальных настроек. Скопируй в .env.local и подставь значения.
# .env.local в .gitignore, .env.example — нет (без секретов).

TRACKER_ADAPTER=linear

# Personal API key из Linear → Settings → Account → Security & access → API keys
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# UUID команды (curl к Linear GraphQL: { teams { nodes { id key name } } })
LINEAR_TEAM_ID=

# Workflow state IDs. Если не задавать — адаптер выберет state с min(position) нужного type.
LINEAR_STATE_ID_NEW=
LINEAR_STATE_ID_PROCESSING=
LINEAR_STATE_ID_DONE=
LINEAR_STATE_ID_FAILED=

# Опциональные фильтры/маппинги
# LINEAR_FETCH_LABEL_ID=
# LINEAR_TASK_TYPE_LABEL_MAPPING={"FEATURE":"<label_id>"}
# LINEAR_FETCH_STATE_TYPES=triage,backlog,unstarted

# --- SCM adapter ---
# Set SCM_ADAPTER=github to use the real GitHub adapter; defaults to "mock".
SCM_ADAPTER=mock

# GitHub adapter (active when SCM_ADAPTER=github)
# REST endpoint. For GitHub Enterprise: https://<host>/api/v3
# GITHUB_API_BASE_URL=https://api.github.com
# Name of the env var that holds the PAT/installation token.
# GITHUB_TOKEN_ENV_VAR=GITHUB_TOKEN
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# Commit author. If empty, falls back to the global git config.
# GITHUB_USER_NAME=heavy-lifting-bot
# GITHUB_USER_EMAIL=bot@example.test
# Remote used by clone/fetch/push and default-branch resolution.
# GITHUB_DEFAULT_REMOTE=origin
# Default repo for single-repo deployments. If a Linear issue does not
# carry repo_url, the GitHub adapter clones this URL. Per-task repo_url
# always overrides the default.
# GITHUB_DEFAULT_REPO_URL=https://github.com/<owner>/<repo>

# SCM-agnostic worker settings (used by ExecuteWorker, not tied to GitHub)
# Fallback for base_branch when neither task nor repo_ref defines one.
# SCM_DEFAULT_BASE_BRANCH=main
# Prefix for auto-generated branch names: <prefix><slug-of-tracker-id>.
# SCM_BRANCH_PREFIX=execute/

# --- Telegram clarification ---
# Use TELEGRAM_ADAPTER=bot for the real Telegram Bot API adapter, or "mock" in tests.
# TELEGRAM_ADAPTER=none
# Env var name that stores the bot token. Do not put the token into logs or committed files.
# TELEGRAM_BOT_TOKEN_ENV_VAR=TELEGRAM_BOT_TOKEN
# TELEGRAM_BOT_TOKEN=000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Predefined group chat id; required when Telegram clarification is enabled.
# TELEGRAM_GROUP_CHAT_ID=-1001234567890
# Optional forum topic/thread id inside the group.
# TELEGRAM_MESSAGE_THREAD_ID=
# TELEGRAM_POLL_INTERVAL=15
# TELEGRAM_FETCH_LIMIT=100
# EXECUTE results with story_points above this threshold are routed to Telegram.
# TELEGRAM_STORY_POINTS_THRESHOLD=8

# --- Runtime settings seeded into DB ---
# These values are used as bootstrap defaults for application_settings.
# After bootstrap, values edited in the UI take priority and apply after restart.
# TRACKER_FETCH_LIMIT=100
# PR_FEEDBACK_FETCH_LIMIT=100
# LOCAL_AGENT_PROVIDER=openai
# LOCAL_AGENT_MODEL=gpt-5.4
# LOCAL_AGENT_NAME=local-placeholder-runner
# CLI_AGENT_PREVIEW_CHARS=1000
