:{$FRONTEND_PORT:80} {
	root * /srv
	basic_auth {
		{$FRONTEND_BASIC_AUTH_USERNAME} {$FRONTEND_BASIC_AUTH_PASSWORD_HASH}
	}

	handle_path /api/* {
		reverse_proxy api:{$APP_PORT:8000} {
			header_up Authorization {http.request.header.Authorization}
		}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
